# =============================================================================
# Unified Agents SDK — Environment Configuration
#
# Copy this file to .env and fill in the values.
# All settings here persist across restarts — no need to re-enter per request.
# Per-request overrides are sent via the "runtime" field in the API body.
# =============================================================================


# -----------------------------------------------------------------------------
# Provider API Keys
# Set whichever providers you use.  Unused keys can be left blank.
# Dedicated providers (groq, deepseek, mistral, xai) have their own keys.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=

# Optional: override base URLs (providers have sensible defaults)
OPENAI_BASE_URL=
DEEPSEEK_BASE_URL=
MISTRAL_BASE_URL=
XAI_BASE_URL=


# -----------------------------------------------------------------------------
# Default Models
# Used when a profile does not specify an explicit model.
# -----------------------------------------------------------------------------
DEFAULT_OPENAI_MODEL=gpt-4o
DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
DEFAULT_GEMINI_MODEL=gemini-2.5-flash
DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_DEEPSEEK_MODEL=deepseek-chat
DEFAULT_MISTRAL_MODEL=mistral-large-latest
DEFAULT_XAI_MODEL=grok-3


# -----------------------------------------------------------------------------
# Extra OpenAI-Compatible Providers
#
# Register additional providers (Together, Ollama, Azure, …) as JSON.
# Each key becomes a valid "provider_name" in AGENT_PROFILES.
# Note: Groq, DeepSeek, Mistral, and xAI now have dedicated adapters
# with full feature support — use their provider keys above instead.
#
# Format:
#   OPENAI_COMPATIBLE_PROVIDERS={"<name>":{"api_key":"...","base_url":"...","model":"..."}}
#
# Examples:
#   OPENAI_COMPATIBLE_PROVIDERS={"together":{"api_key":"...","base_url":"https://api.together.xyz/v1","model":"meta-llama/Llama-3.3-70B-Instruct-Turbo"},"ollama":{"base_url":"http://localhost:11434/v1","model":"llama3"}}
# -----------------------------------------------------------------------------
OPENAI_COMPATIBLE_PROVIDERS={}


# -----------------------------------------------------------------------------
# Agent Profiles
#
# Named configurations that map a profile name to a provider + model + presets.
# The "profile" field in every API request selects one of these entries.
# Lookup order: "{agent_id}:{profile}" → "{profile}" → "default"
#
# Fields per profile:
#   provider_name   — "openai_compatible" | "openai_responses" | "anthropic" | "gemini" | "groq" | "deepseek" | "mistral" | "xai" | key from OPENAI_COMPATIBLE_PROVIDERS
#   model           — (optional) override the default model for this provider
#   api_key         — (optional) override the provider API key for this profile
#   base_url        — (optional) override the base URL (OAI-compatible only)
#   mcp_namespaces  — (optional) list of MCP_SERVERS keys always active for this profile
#   context_names   — (optional) list of NAMED_CONTEXTS keys always active for this profile
#
# Examples:
#   AGENT_PROFILES={"default":{"provider_name":"openai_compatible"},
#                   "openai-r":{"provider_name":"openai_responses","model":"gpt-4o"},
#                   "claude":{"provider_name":"anthropic","model":"claude-opus-4-5"},
#                   "gemini":{"provider_name":"gemini","model":"gemini-2.5-pro"},
#                   "fast":{"provider_name":"groq","model":"llama-3.3-70b-versatile"},
#                   "deep":{"provider_name":"deepseek","model":"deepseek-reasoner"},
#                   "mistral":{"provider_name":"mistral","model":"mistral-large-latest"},
#                   "grok":{"provider_name":"xai","model":"grok-4.20-reasoning"},
#                   "researcher":{"provider_name":"openai_responses","mcp_namespaces":["search"],"context_names":["company_info"]}}
# -----------------------------------------------------------------------------
AGENT_PROFILES={"default":{"provider_name":"openai_compatible"}}


# -----------------------------------------------------------------------------
# Named MCP Server Presets
#
# Define MCP servers here once; reference them by key in API calls via
# "runtime.mcp_namespaces": ["search"] — credentials never leave the server.
#
# Format (JSON):
#   MCP_SERVERS={"<namespace>":{"url":"...","transport":"streamable_http|sse","headers":{"Authorization":"Bearer ..."},"timeout_seconds":30}}
#
# Transports:
#   streamable_http — recommended for MCP servers ≥ 2024-11-05
#   sse             — legacy HTTP+SSE transport
#
# Examples:
#   MCP_SERVERS={"search":{"url":"http://search-mcp.internal/mcp","transport":"streamable_http","headers":{"Authorization":"Bearer sk-search"}},
#                "files":{"url":"http://files-mcp.internal/sse","transport":"sse","timeout_seconds":60},
#                "code":{"url":"http://code-mcp.internal/mcp","transport":"streamable_http"}}
# -----------------------------------------------------------------------------
MCP_SERVERS={}


# -----------------------------------------------------------------------------
# Named Context Presets
#
# Static or HTTP-fetched context snippets injected into every agent prompt.
# Reference them by key in API calls via "runtime.context_names": ["company_info"].
# Attach them permanently to a profile via "context_names" in AGENT_PROFILES.
#
# Fields:
#   mode            — "static" (text literal) | "http" (fetch from URL per request)
#   source          — "static" | "rag" | "kv" | "context_forge" (informational tag)
#   text            — content for mode=static; supports {input} template vars
#   url             — endpoint for mode=http
#   method          — "GET" | "POST"  (default: POST)
#   headers         — request headers for mode=http
#   payload_template — JSON body template for mode=http; {input} is substituted
#   required        — if true, a fetch failure raises an error instead of silently skipping
#   max_chars       — truncate fetched content to this length
#
# Examples:
#   NAMED_CONTEXTS={"company_info":{"mode":"static","text":"We are Acme Corp, founded 1923. Our products are ..."},
#                   "product_faq":{"mode":"http","source":"rag","url":"http://kb.internal/search","payload_template":{"query":"{input}"},"max_chars":4000},
#                   "user_policy":{"mode":"http","source":"kv","url":"http://policy-api/fetch","method":"GET","required":true}}
# -----------------------------------------------------------------------------
NAMED_CONTEXTS={}


# -----------------------------------------------------------------------------
# ContextForge (shorthand — alternatively define it in NAMED_CONTEXTS)
# -----------------------------------------------------------------------------
CONTEXTFORGE_URL=
CONTEXTFORGE_API_KEY=


# -----------------------------------------------------------------------------
# Reliability
# -----------------------------------------------------------------------------
MODEL_TIMEOUT_SECONDS=60
TOOL_TIMEOUT_SECONDS=30
MAX_TOOL_HOPS=6


# -----------------------------------------------------------------------------
# Dynamic Runtime Registration
#
# Controls whether callers may specify inline tools / MCP servers / contexts
# in the "runtime" field of an API request.
# Set to false in locked-down production environments.
# -----------------------------------------------------------------------------
ALLOW_DYNAMIC_RUNTIME_REGISTRATION=true


# -----------------------------------------------------------------------------
# Per-request LLM credentials (BYOK)
#
# When true, clients may send "provider_credentials" in the JSON body
# (api_key, optional model, optional base_url for OpenAI-compatible only).
# Default false — keys in bodies are easy to leak via logs and proxies.
# -----------------------------------------------------------------------------
ALLOW_PER_REQUEST_PROVIDER_CREDENTIALS=false
